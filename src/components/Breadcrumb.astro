---
import { BASE_PATH } from "@/config";

const currentUrlPath = Astro.url.pathname
  .replace(/\/+$/, "")
  .replace(new RegExp(`^${BASE_PATH}`), "");
const breadcrumbList = currentUrlPath.split("/").slice(1);

if (breadcrumbList[0] === "posts") {
  breadcrumbList.splice(0, 2, `资料（第 ${breadcrumbList[1] || 1} 页）`);
}

if (breadcrumbList[0] === "tags" && !isNaN(Number(breadcrumbList[2]))) {
  breadcrumbList.splice(
    1,
    3,
    `${breadcrumbList[1]}${Number(breadcrumbList[2]) === 1 ? "" : `（第 ${breadcrumbList[2]} 页）`}`
  );
}

const breadcrumbLabelMap: Record<string, string> = {
  posts: "资料",
  tags: "标签",
  about: "关于",
  archives: "归档",
  search: "搜索",
};

const formatBreadcrumb = (breadcrumb: string, isLast: boolean) => {
  const decoded = decodeURIComponent(breadcrumb);
  if (breadcrumbLabelMap[decoded]) return breadcrumbLabelMap[decoded];
  return isLast ? decoded : decoded;
};
---

<nav class="app-layout mt-8 mb-1" aria-label="面包屑导航">
  <ul
    class="font-light [&>li]:inline [&>li:not(:last-child)>a]:hover:opacity-100"
  >
    <li>
      <a href={BASE_PATH} class="opacity-80">首页</a>
      <span aria-hidden="true" class="opacity-80">&raquo;</span>
    </li>
    {
      breadcrumbList.map((breadcrumb, index) =>
        index + 1 === breadcrumbList.length ? (
          <li>
            <span class="opacity-75" aria-current="page">
              {formatBreadcrumb(breadcrumb, true)}
            </span>
          </li>
        ) : (
          <li>
            <a href={`${BASE_PATH}/${breadcrumb}/`} class="opacity-70">
              {formatBreadcrumb(breadcrumb, false)}
            </a>
            <span aria-hidden="true">&raquo;</span>
          </li>
        )
      )
    }
  </ul>
</nav>
